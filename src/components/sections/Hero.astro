---
import { Image } from "astro:assets";
import ridwanPicture from "@assets/images/ridwan-picture.avif";
---

<section>
  <div class="flex items-center gap-4">
    <Image
      class="size-32 aspect-square object-cover object-center rounded-full shadow-sm"
      src={ridwanPicture}
      alt="ridwan picture"
    />
    <div>
      <h1 class="font-bold text-xl">Ridwan Muhammad Raihan</h1>
      <h2 class="text-neutral-500 text-sm">Software Engineer</h2>
    </div>
  </div>
</section>
